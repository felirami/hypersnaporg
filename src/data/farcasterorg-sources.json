    "bootstrapCommand": "curl -sSL https://raw.githubusercontent.com/farcasterorg/hypersnap/refs/heads/main/scripts/hypersnap-bootstrap.sh | bash",
    "nightlyCommand": "curl -sSL https://raw.githubusercontent.com/farcasterorg/hypersnap/refs/heads/main/scripts/hypersnap-bootstrap.sh | bash -s nightly",
    "commands": [
      {
        "label": "Upgrade",
        "command": "cd ~/hypersnap && ./hypersnap.sh upgrade"
      },
      {
        "label": "Logs",
        "command": "cd ~/hypersnap && ./hypersnap.sh logs"
      },
      {
        "label": "Stop",
        "command": "cd ~/hypersnap && ./hypersnap.sh down"
      },
      {
        "label": "Local info",
        "command": "curl http://localhost:3381/v1/info | jq ."
      }
    ],
    "requirements": [
      "16 GB RAM",
      "4 CPU cores or vCPUs",
      "1.5 TB free storage",
      "Public IP address",
      "Ports 3381-3383 exposed on TCP and UDP"
    ],
    "ports": [
      "3381/tcp HTTP",
      "3382/udp gossip",
      "3383/tcp gRPC"
    ],
    "noRewardsNotice": "The network has not yet released a token. Running a node at this time will not earn tokens."
